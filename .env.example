# ============================================================
# LinkedIn AI Agent — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_NAME="LinkedIn AI Agent"
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./linkedin_agent.db
# For PostgreSQL (future):
# DATABASE_URL=postgresql://user:password@localhost:5432/linkedin_agent

# ─── AI Providers ───────────────────────────────────────────
# Primary AI provider: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.8

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# ─── Image Providers ────────────────────────────────────────
# Priority order for image fetching (comma-separated)
IMAGE_PROVIDER_PRIORITY=unsplash,pexels,pixabay,dalle

# Unsplash (https://unsplash.com/developers)
UNSPLASH_API_KEY=your-unsplash-access-key-here

# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key-here

# Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=your-pixabay-api-key-here

# DALL-E uses OpenAI key above
DALLE_IMAGE_SIZE=1024x1024
DALLE_IMAGE_QUALITY=hd
DALLE_IMAGE_STYLE=vivid

# ─── LinkedIn API ───────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback
# Your LinkedIn Person URN (found in profile URL or via API)
LINKEDIN_PERSON_URN=urn:li:person:your-person-id

# ─── Scheduler ──────────────────────────────────────────────
# Daily post generation time (24h format, local time)
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Karachi

# ─── Content Configuration ──────────────────────────────────
# Default topics (comma-separated)
DEFAULT_TOPICS=Artificial Intelligence,Data Analytics,Python,Machine Learning,Power BI,Cloud Computing,Career Advice,Productivity,Tech News,Software Engineering

# Post language
POST_LANGUAGE=English

# Max hashtags per post
MAX_HASHTAGS=10

# Min/Max post length (characters)
POST_MIN_LENGTH=500
POST_MAX_LENGTH=2500

# ─── Memory ─────────────────────────────────────────────────
MEMORY_FILE_PATH=./data/memory.json
MAX_HISTORY_DAYS=365

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/agent.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
